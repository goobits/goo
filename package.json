	"files": [
		"src",
		"!src/**/__tests__/**",
		"!src/**/*.test.ts"
	],
	"scripts": {
		"dev": "vite --host 127.0.0.1",
		"test": "vitest run",
		"check": "pnpm run lint:check && pnpm run check:svelte && pnpm run check:types",
		"check:svelte": "node scripts/checkSvelteConventions.mjs && svelte-check --tsconfig ./tsconfig.json",
		"check:types": "tsc --noEmit",
		"lint": "eslint src/ --fix",
		"lint:check": "eslint src/",
		"test:e2e": "env -u NO_COLOR xvfb-run -a pnpm exec playwright test",
		"test:all": "pnpm run test && pnpm run test:e2e"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
