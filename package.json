{
	"name": "@goobits/goo",
	"version": "0.1.0",
	"description": "Modern UI components with CSS custom properties. Clean, accessible form elements.",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@10.13.1",
	"exports": {
		".": "./src/index.ts",
		"./button": "./src/button/index.ts",
		"./button/styles.css": "./src/button/GooButton.css",
		"./button-group": "./src/button-group/index.ts",
		"./button-group/styles.css": "./src/button-group/GooButtonGroup.css",
		"./checkbox": "./src/checkbox/index.ts",
		"./input": "./src/input/index.ts",
		"./input/styles.css": "./src/input/GooInput.css",
		"./radio": "./src/radio/index.ts",
		"./select": "./src/select/index.ts",
		"./select/styles.css": "./src/select/GooSelect.css",
		"./slider": "./src/slider/index.ts",
		"./spinner": "./src/spinner/index.ts",
		"./angle-input": "./src/angle-input/index.ts",
		"./textarea": "./src/textarea/index.ts",
		"./dialog": "./src/dialog/index.ts",
		"./floating-window": "./src/floating-window/index.ts",
		"./popout": "./src/popout/index.ts",
		"./positioning": "./src/positioning/index.ts",
		"./progress-ring": "./src/progress-ring/index.ts",
		"./context-menu": "./src/context-menu/index.ts",
		"./data-grid": "./src/data-grid/index.ts",
		"./folder": "./src/folder/index.ts",
		"./panel": "./src/panel/index.ts",
		"./controller": "./src/controller/index.ts",
		"./color": "./src/color/index.ts",
		"./i18n": "./src/i18n/index.ts",
		"./icon": "./src/icon/index.ts",
		"./icon/registry": "./src/icon/registry.ts",
		"./label": "./src/label/index.ts",
		"./number": "./src/number/index.ts",
		"./tooltip": "./src/tooltip/index.ts",
		"./vortex": "./src/vortex/index.ts",
		"./virtualGrid": "./src/virtualGrid/index.ts",
		"./schema": "./src/schema/index.ts",
		"./table": "./src/table/index.ts",
		"./components/diff": "./src/components/diff/index.ts",
		"./error-boundary": "./src/error-boundary/index.ts",
		"./turnstile": "./src/turnstile/index.ts",
		"./toast": "./src/toast/index.ts"
	},
	"files": [
		"src"
	],
	"scripts": {
		"dev": "vite --host 127.0.0.1",
		"test": "vitest run",
		"check": "pnpm run lint:check && pnpm run check:svelte && pnpm run check:types",
		"check:svelte": "node scripts/checkSvelteConventions.mjs && svelte-check --tsconfig ./tsconfig.json",
		"check:types": "tsc --noEmit",
		"lint": "eslint src/ --fix",
		"lint:check": "eslint src/",
		"test:e2e": "env -u NO_COLOR xvfb-run -a pnpm exec playwright test",
		"test:all": "pnpm run test && pnpm run test:e2e"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@testing-library/svelte": "^5.3.1",
		"eslint": "^10.3.0",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"jsdom": "^29.1.1",
		"svelte": "^5.55.5",
		"svelte-check": "4.4.8",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@goobits/logger": "^1.0.0"
	},
	"peerDependencies": {
		"svelte": "^5.55.5"
	},
	"keywords": [
		"ui",
		"components",
		"button",
		"range",
		"checkbox",
		"input",
		"form",
		"web-components",
		"custom-elements"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/goobits/goo.git"
	},
	"homepage": "https://github.com/goobits/goo#readme",
	"bugs": "https://github.com/goobits/goo/issues",
	"author": "Goobits",
	"license": "SketchAPI"
}
